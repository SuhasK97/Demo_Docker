pipeline {
    agent any

    environment {
        // Define your Docker image name
        DOCKER_IMAGE = "node-docker-demo"
        // Use the build number to version your images
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                // Pulls code from your Git repository
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    // Build the image using the optimized Dockerfile we created
                    sh "docker build -t ${DOCKER_IMAGE}:${IMAGE_TAG} ."
                    sh "docker tag ${DOCKER_IMAGE}:${IMAGE_TAG} ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Test') {
            steps {
                // Example: Running a simple check to see if the container starts
                sh "docker run --rm ${DOCKER_IMAGE}:${IMAGE_TAG} node -v"
            }
        }

        stage('Cleanup') {
            steps {
                // Remove older images to save disk space on the Jenkins agent
                sh "docker image prune -f"
            }
        }
    }

    post {
        success {
            echo "Successfully built ${DOCKER_IMAGE}:${IMAGE_TAG}"
        }
        failure {
            echo "Pipeline failed. Check the logs for errors."
        }
    }
}
