pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/SuhasK97/Demo_Docker.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('docker-demo') {
                    sh 'docker build -t demo_docker .'
                }
            }
        }

        stage('Run Docker Container') {
            steps {
                sh 'docker run -d --name demo_container demo_docker'
            }
        }

    }
}
