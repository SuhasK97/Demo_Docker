pipeline {
    agent any

    environment {
        IMAGE_NAME = "suhas1997/go_docker_app:latest"
        // This helper automatically creates DOCKER_HUB_USR and DOCKER_HUB_PSW
        DOCKER_HUB = credentials('dockerhub-credentials')
    }

    stages {
        stage('Checkout Code') {
            steps {
                // Fixed: The git step expects specific parameters, not a comma-separated list like this
                git(
                    branch: 'main', 
                    credentialsId: 'github-token', 
                    url: 'https://github.com/SuhasK97/go-docker-app.git'
                )
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t go_docker_app .'
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                docker stop go_container || true
                docker rm go_container || true
                docker run -d --name go_container go_docker_app
                '''
            }
        }

        stage('Push Docker Image') {
            steps {
                // You MUST login before pushing, or the stage will fail with 'Permission Denied'
                sh "echo ${DOCKER_HUB_PSW} | docker login -u ${DOCKER_HUB_USR} --password-stdin"
                sh "docker tag go_docker_app:latest ${IMAGE_NAME}"
                sh "docker push ${IMAGE_NAME}"
            }
        }
    }

    post {
        always {
            // Good practice: remove credentials from the Jenkins agent after the run
            sh 'docker logout'
        }
    }
}
