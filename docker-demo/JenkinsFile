pipeline {
    agent any

    environment {
        // Defined here so it's available in all stages
        IMAGE_NAME = "suhas1997/go_docker_app:latest"
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/SuhasK97/go-docker-app.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t go_docker_app .'
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                docker stop go_container || true
                docker rm go_container || true
                docker run -d -p 8080:8080 --name go_container go_docker_app
                '''
            }
        }

        stage('Tag Docker Image') {
            steps {
                // Use double quotes so Jenkins can interpolate the ${IMAGE_NAME} variable
                sh "docker tag go_docker_app:latest ${env.IMAGE_NAME}"
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials', 
                    usernameVariable: 'DOCKER_USER', 
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                    docker push ${IMAGE_NAME}
                    '''
                }
            }
        }
    }

    post {
        always {
            // Clean up login credentials from the runner
            sh 'docker logout'
        }
    }
}
