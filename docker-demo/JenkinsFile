pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/SuhasK97/Demo_Docker.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t node-docker-demo:20 ./docker-demo'
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker stop node_container || true
                docker rm node_container || true
                docker run -d -p 3000:3000 --name node_container node-docker-demo:20
                '''
            }
        }

        stage('Push Image') {
            steps {
                sh '''
                docker tag node-docker-demo:20 suhas1997/node-docker-demo:20
                docker push suhas1997/node-docker-demo:20
                '''
            }
        }
    }
}
